{
  "title": "CodeGuardian AI — Platform Overview",
  "uid": "codeguardian-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["codeguardian", "reviews", "llm"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate (by status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(cg_http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP error ratio (5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "sum(rate(cg_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(cg_http_requests_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Review queue depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "cg_review_queue_depth" }]
    },
    {
      "id": 4,
      "title": "Review latency (p50 / p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cg_review_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cg_review_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Per-agent latency (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, agent) (rate(cg_agent_seconds_bucket[5m])))",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Agent success vs error rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(cg_agent_runs_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "LLM cost rate (USD/hr, by provider)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "expr": "sum by (provider) (rate(cg_llm_cost_micros_total[5m])) * 3600 / 1e6",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "LLM tokens/sec (by provider)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(cg_llm_tokens_total[5m]))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Cost per review (USD, last 1h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "expr": "sum(increase(cg_llm_cost_micros_total[1h])) / clamp_min(sum(increase(cg_reviews_total[1h])), 1) / 1e6"
        }
      ]
    }
  ]
}
