# CodeGuardian AI — backend environment (DEVELOPMENT EXAMPLE ONLY)
# Copy to `.env` for local dev. NEVER commit a real `.env`. In staging/production
# these values come from a secret manager (Vault / cloud KMS), not files. (PRD §9.6)
#
# All variables are prefixed CG_ and validated by app/config.py (unknown vars are rejected).

# --- Runtime ---------------------------------------------------------------
CG_ENVIRONMENT=development           # development | staging | production | test
CG_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
CG_SERVICE_NAME=codeguardian-api

# --- Datastores (DSNs; credentials belong to the secret manager in prod) ---
# Dev default uses the docker-compose Postgres. Tests use in-memory SQLite automatically.
CG_DATABASE_URL=postgresql+psycopg://codeguardian:codeguardian@localhost:5432/codeguardian
CG_REDIS_URL=redis://localhost:6379/0

# --- GitHub webhook security (PRD §9.1) -----------------------------------
# The shared secret you configure on the GitHub App webhook. REQUIRED in production.
CG_GITHUB_WEBHOOK_SECRET=change-me-in-dev-only
CG_WEBHOOK_REPLAY_WINDOW_SECONDS=300
CG_WEBHOOK_MAX_BODY_BYTES=5242880

# --- GitHub App auth (Phase 1; short-lived tokens, no PATs) ----------------
# CG_GITHUB_APP_ID=123456
# CG_GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...   (from secret manager)

# --- LLM providers (Phase 1) ----------------------------------------------
# CG_ANTHROPIC_API_KEY=sk-ant-...    (from secret manager)
CG_PER_PR_TOKEN_BUDGET=120000
